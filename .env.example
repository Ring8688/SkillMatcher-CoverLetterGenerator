# Copy to .env and fill in your API configuration.
# API_TYPE: "anthropic" (default) or "openai"
#   anthropic → POST {base_url}/v1/messages (Anthropic SDK)
#   openai    → POST {base_url}/chat/completions (OpenAI SDK)

API_TYPE=anthropic
API_BASE_URL=http://your-host:42069
API_KEY=your-api-key-here
API_MODEL=claude-sonnet-4-6
API_TEMPERATURE=0
